# Required API Keys
# Get from: https://console.anthropic.com
NEBIUS_API_KEY=your_nebius_api_key_here

# Get from: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: Pinterest API (only needed for Phase 4)
# Get from: https://developers.pinterest.com
PINTEREST_API_KEY=your_pinterest_api_key_here
PINTEREST_API_SECRET=your_pinterest_api_secret_here
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token_here

# Configuration
OUTPUT_DIR=./outputs
LOG_LEVEL=INFO
